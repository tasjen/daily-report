{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daily Report",
  "version": "1.0.0",
  "identifier": "com.livinginsider.daily-report",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Daily Report",
        "width": 1200,
        "height": 900,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tasjen/daily-report/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDQjZCRTc2NTg2RkIwMEIKUldRTHNHOVlkcjYyVEJ6ejFvTzE2Nlhtc2RXVXR5QmFBdjFVdkNlNjVsZ2NTSTdxQ0NhY3lpSzIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
