{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://living-insider.atlassian.net/**"
        }
      ]
    },
    "core:window:allow-set-focus"
  ]
}
