{
  "name": "daily-report",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "extract": "lingui extract",
    "start": "tauri dev --config src-tauri/tauri.conf.dev.json",
    "package": "tauri build",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "wdio run e2e/wdio.conf.ts",
    "bump": "node scripts/bump-version.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf dist node_modules/.vite && pnpm i"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
